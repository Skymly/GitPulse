<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GitPulse.ViewModels;assembly=GitPulse.ViewModels"
             xmlns:models="clr-namespace:GitPulse.Core.Models;assembly=GitPulse.Core"
             xmlns:idk="clr-namespace:Indiko.Maui.Controls.Markdown;assembly=Indiko.Maui.Controls.Markdown"
             x:Class="GitPulse.App.Views.RepoDetailPage"
             x:DataType="vm:RepoDetailViewModel"
             Title="Repository">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Back button + repo full name -->
        <HorizontalStackLayout Grid.Row="0" Spacing="12" Padding="16,12,16,4">
            <Button Text="← Back"
                    Clicked="OnBackClicked"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    Padding="8,4" />
            <Label Text="{Binding RepoFullName.Value}"
                   FontSize="18"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   LineBreakMode="TailTruncation"
                   MaxLines="1" />
        </HorizontalStackLayout>

        <!-- Tab bar: Overview / Branches / Releases -->
        <HorizontalStackLayout Grid.Row="1" Spacing="8" Padding="16,0,16,8">
            <Button x:Name="OverviewTab"
                    Text="Overview"
                    Clicked="OnOverviewTabClicked"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    Padding="16,6"
                    FontSize="13" />
            <Button x:Name="BranchesTab"
                    Text="Branches"
                    Clicked="OnBranchesTabClicked"
                    BackgroundColor="{StaticResource Gray200}"
                    TextColor="Black"
                    Padding="16,6"
                    FontSize="13" />
            <Button x:Name="ReleasesTab"
                    Text="Releases"
                    Clicked="OnReleasesTabClicked"
                    BackgroundColor="{StaticResource Gray200}"
                    TextColor="Black"
                    Padding="16,6"
                    FontSize="13" />
        </HorizontalStackLayout>

        <!-- Tab content area -->
        <Grid Grid.Row="2">

            <!-- ── Overview tab ────────────────────────────────────── -->
            <ScrollView x:Name="OverviewSection">
                <VerticalStackLayout Padding="16" Spacing="12">

                    <!-- Repo metadata card -->
                    <Border StrokeShape="RoundRectangle 8"
                             Stroke="{StaticResource Gray200}"
                             Padding="16"
                             IsVisible="{Binding Repo.Value, Converter={StaticResource NotNullConverter}}">
                        <VerticalStackLayout Spacing="8">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{Binding Repo.Value.Name}"
                                       FontSize="20"
                                       FontAttributes="Bold" />
                                <Label Text="private"
                                       FontSize="11"
                                       TextColor="{StaticResource Gray500}"
                                       IsVisible="{Binding Repo.Value.Private}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <Label Text="{Binding Repo.Value.Description}"
                                   FontSize="14"
                                   TextColor="{StaticResource Gray600}"
                                   IsVisible="{Binding Repo.Value.Description, Converter={StaticResource StringToBoolConverter}}" />

                            <HorizontalStackLayout Spacing="16" Margin="0,4,0,0">
                                <Label Text="{Binding Repo.Value.StargazersCount, StringFormat='★ {0}'}"
                                       FontSize="13"
                                       TextColor="{StaticResource Gray500}" />
                                <Label Text="{Binding Repo.Value.ForksCount, StringFormat='⑂ {0}'}"
                                       FontSize="13"
                                       TextColor="{StaticResource Gray500}" />
                                <Label Text="{Binding Repo.Value.OpenIssuesCount, StringFormat='⚠ {0}'}"
                                       FontSize="13"
                                       TextColor="{StaticResource Gray500}" />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="16" Margin="0,2,0,0">
                                <Label Text="{Binding Repo.Value.DefaultBranch, StringFormat='Default: {0}'}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray500}" />
                                <Label Text="{Binding Repo.Value.UpdatedAt, StringFormat='Updated {0:yyyy-MM-dd}'}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray500}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Navigation buttons -->
                    <HorizontalStackLayout Spacing="12">
                        <Button Text="Issues →"
                                Clicked="OnIssuesClicked"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                Padding="16,6"
                                FontSize="13" />
                        <Button Text="PRs →"
                                Clicked="OnPullRequestsClicked"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource Primary}"
                                Padding="16,6"
                                FontSize="13" />
                        <Button Text="Files →"
                                Clicked="OnFilesClicked"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource Primary}"
                                Padding="16,6"
                                FontSize="13" />
                        <Button Text="Actions →"
                                Clicked="OnActionsClicked"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource Primary}"
                                Padding="16,6"
                                FontSize="13" />
                        <Button Text="↗ Browser"
                                Command="{Binding OpenInBrowserCommand}"
                                CommandParameter="{Binding Repo.Value.HtmlUrl}"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource Primary}"
                                Padding="16,6"
                                FontSize="13" />
                    </HorizontalStackLayout>

                    <!-- README section -->
                    <Label Text="README"
                           FontSize="16"
                           FontAttributes="Bold"
                           Margin="0,8,0,4"
                           IsVisible="{Binding HasReadme.Value}" />

                    <idk:MarkdownView MarkdownText="{Binding ReadmeMarkdown.Value}"
                                      UseAppTheme="True"
                                      H1FontSize="20"
                                      H2FontSize="18"
                                      H3FontSize="16"
                                      TextFontSize="14"
                                      IsVisible="{Binding HasReadme.Value}" />

                    <!-- No README placeholder -->
                    <Border StrokeShape="RoundRectangle 8"
                             Stroke="{StaticResource Gray200}"
                             Padding="16"
                             IsVisible="{Binding HasReadme.Value, Converter={StaticResource InvertedBoolConverter}}">
                        <Label Text="No README found for this repository."
                               FontSize="14"
                               TextColor="{StaticResource Gray500}"
                               HorizontalOptions="Center" />
                    </Border>

                    <!-- Error banner -->
                    <Border IsVisible="{Binding ErrorMessage.Value, Converter={StaticResource StringToBoolConverter}}"
                            BackgroundColor="{StaticResource Red100}"
                            StrokeShape="RoundRectangle 8"
                            Padding="12">
                        <Label Text="{Binding ErrorMessage.Value}"
                               TextColor="{StaticResource Red900}"
                               FontSize="13" />
                    </Border>

                    <!-- Loading indicator -->
                    <ActivityIndicator IsRunning="{Binding IsLoading.Value}"
                                       IsVisible="{Binding IsLoading.Value}" />
                </VerticalStackLayout>
            </ScrollView>

            <!-- ── Branches tab ────────────────────────────────────── -->
            <ScrollView x:Name="BranchesSection" IsVisible="False">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <ActivityIndicator IsRunning="{Binding IsLoadingBranches.Value}"
                                       IsVisible="{Binding IsLoadingBranches.Value}" />
                    <CollectionView ItemsSource="{Binding Branches}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Branch">
                                <Border StrokeShape="RoundRectangle 8"
                                         Stroke="{StaticResource Gray200}"
                                         Padding="12"
                                         Margin="0,0,0,8">
                                    <VerticalStackLayout Spacing="4">
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontAttributes="Bold" />
                                            <Label Text="protected"
                                                   FontSize="11"
                                                   TextColor="{StaticResource Gray500}"
                                                   IsVisible="{Binding Protected}"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding Commit.Sha, Converter={StaticResource StringTruncateConverter}, ConverterParameter=8}"
                                               FontSize="11"
                                               FontFamily="OpenSansRegular"
                                               TextColor="{StaticResource Gray500}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>

            <!-- ── Releases tab ────────────────────────────────────── -->
            <ScrollView x:Name="ReleasesSection" IsVisible="False">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <ActivityIndicator IsRunning="{Binding IsLoadingReleases.Value}"
                                       IsVisible="{Binding IsLoadingReleases.Value}" />
                    <CollectionView ItemsSource="{Binding Releases}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Release">
                                <Border StrokeShape="RoundRectangle 8"
                                         Stroke="{StaticResource Gray200}"
                                         Padding="14"
                                         Margin="0,0,0,10">
                                    <VerticalStackLayout Spacing="6">
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="{Binding TagName}"
                                                   FontSize="15"
                                                   FontAttributes="Bold" />
                                            <Label Text="draft"
                                                   FontSize="11"
                                                   TextColor="{StaticResource Gray500}"
                                                   IsVisible="{Binding Draft}"
                                                   VerticalOptions="Center" />
                                            <Label Text="pre-release"
                                                   FontSize="11"
                                                   TextColor="{StaticResource Purple700}"
                                                   IsVisible="{Binding Prerelease}"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding Name}"
                                               FontSize="13"
                                               IsVisible="{Binding Name, Converter={StaticResource StringToBoolConverter}}" />
                                        <idk:MarkdownView MarkdownText="{Binding Body}"
                                                          UseAppTheme="True"
                                                          H1FontSize="16"
                                                          H2FontSize="15"
                                                          H3FontSize="14"
                                                          TextFontSize="13"
                                                          IsVisible="{Binding Body, Converter={StaticResource StringToBoolConverter}}" />
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="{Binding Author.Login, StringFormat='by {0}'}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource Gray500}" />
                                            <Label Text="{Binding PublishedAt, StringFormat='{0:yyyy-MM-dd}'}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource Gray500}" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>

        </Grid>

    </Grid>

</ContentPage>
