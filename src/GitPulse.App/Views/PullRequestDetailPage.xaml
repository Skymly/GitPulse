<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GitPulse.ViewModels;assembly=GitPulse.ViewModels"
             xmlns:models="clr-namespace:GitPulse.Core.Models;assembly=GitPulse.Core"
             xmlns:idk="clr-namespace:Indiko.Maui.Controls.Markdown;assembly=Indiko.Maui.Controls.Markdown"
             x:Class="GitPulse.App.Views.PullRequestDetailPage"
             x:DataType="vm:PullRequestDetailViewModel"
             Title="PR Detail">

    <Grid RowDefinitions="Auto,*">

        <!-- Back button + title -->
        <HorizontalStackLayout Grid.Row="0" Spacing="12" Padding="16,12,16,4">
            <Button Text="Back"
                    Clicked="OnBackClicked"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    Padding="8,4" />
            <Label Text="{Binding Title.Value}"
                   FontSize="18"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   LineBreakMode="TailTruncation"
                   MaxLines="1" />
        </HorizontalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="12">

                <!-- PR header -->
                <Border StrokeShape="RoundRectangle 8"
                         Stroke="{StaticResource Gray200}"
                         Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="{Binding PullRequest.Value.State}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Green700}"
                                   IsVisible="{Binding PullRequest.Value.State, Converter={StaticResource StringEqualsConverter}, ConverterParameter=open}" />
                            <Label Text="{Binding PullRequest.Value.State}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Purple700}"
                                   IsVisible="{Binding PullRequest.Value.State, Converter={StaticResource StringEqualsConverter}, ConverterParameter=closed}" />
                            <Label Text="draft"
                                   FontSize="12"
                                   FontAttributes="Italic"
                                   TextColor="{StaticResource Orange900}"
                                   IsVisible="{Binding PullRequest.Value.Draft}" />
                            <Label Text="merged"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Purple700}"
                                   IsVisible="{Binding PullRequest.Value.Merged}" />
                            <Label Text="{Binding PullRequest.Value.User.Login, StringFormat='by {0}'}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray500}" />
                            <Label Text="{Binding PullRequest.Value.CreatedAt, StringFormat='{0:yyyy-MM-dd}'}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray500}" />
                        </HorizontalStackLayout>

                        <!-- Branch ref line: head → base -->
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="{Binding PullRequest.Value.HeadRef}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray600}" />
                            <Label Text="→"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray500}" />
                            <Label Text="{Binding PullRequest.Value.BaseRef}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray600}" />
                        </HorizontalStackLayout>

                        <idk:MarkdownView MarkdownText="{Binding PullRequest.Value.Body}"
                                          UseAppTheme="True"
                                          H1FontSize="20"
                                          H2FontSize="18"
                                          H3FontSize="16"
                                          TextFontSize="14" />
                    </VerticalStackLayout>
                </Border>

                <!-- Open in browser + state toggle -->
                <HorizontalStackLayout Spacing="12">
                    <Button Text="Open in browser ↗"
                            Command="{Binding OpenInBrowserCommand}"
                            CommandParameter="{Binding PullRequest.Value.HtmlUrl}"
                            Padding="16,6"
                            FontSize="13" />
                    <Button Text="Close"
                            Command="{Binding ToggleStateCommand}"
                            IsVisible="{Binding PullRequest.Value.State, Converter={StaticResource StringEqualsConverter}, ConverterParameter=open}"
                            BackgroundColor="{StaticResource Purple700}"
                            TextColor="White"
                            Padding="16,6"
                            FontSize="13" />
                    <Button Text="Reopen"
                            Command="{Binding ToggleStateCommand}"
                            IsVisible="{Binding PullRequest.Value.State, Converter={StaticResource StringEqualsConverter}, ConverterParameter=closed}"
                            BackgroundColor="{StaticResource Green700}"
                            TextColor="White"
                            Padding="16,6"
                            FontSize="13" />
                </HorizontalStackLayout>

                <!-- M6: PR merge section -->
                <Border StrokeShape="RoundRectangle 8"
                         Stroke="{StaticResource Gray200}"
                         Padding="16"
                         IsVisible="{Binding PullRequest.Value, Converter={StaticResource NotNullConverter}}">
                    <VerticalStackLayout Spacing="10">
                        <!-- Merge status label -->
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="Merge status:"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray600}" />
                            <Label Text="{Binding MergeStatus.Value}"
                                   FontSize="13"
                                   TextColor="{StaticResource Primary}" />
                        </HorizontalStackLayout>

                        <!-- PR stats: commits, additions, deletions, changed files -->
                        <HorizontalStackLayout Spacing="16">
                            <Label Text="{Binding PullRequest.Value.Commits, StringFormat='{0} commits'}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray500}" />
                            <Label Text="{Binding PullRequest.Value.Additions, StringFormat='+{0}'}"
                                   FontSize="12"
                                   TextColor="{StaticResource Green700}" />
                            <Label Text="{Binding PullRequest.Value.Deletions, StringFormat='-{0}'}"
                                   FontSize="12"
                                   TextColor="{StaticResource Red900}" />
                            <Label Text="{Binding PullRequest.Value.ChangedFiles, StringFormat='{0} files'}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray500}" />
                        </HorizontalStackLayout>

                        <!-- Merge method picker + merge button (visible when mergeable) -->
                        <HorizontalStackLayout Spacing="12"
                                               IsVisible="{Binding CanMerge.Value}">
                            <Picker Title="Method"
                                    SelectedItem="{Binding MergeMethod.Value}"
                                    FontSize="13">
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>merge</x:String>
                                        <x:String>squash</x:String>
                                        <x:String>rebase</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                            </Picker>
                            <Button Text="Merge"
                                    Command="{Binding MergeCommand}"
                                    BackgroundColor="{StaticResource Green700}"
                                    TextColor="White"
                                    Padding="24,8"
                                    FontSize="14" />
                            <ActivityIndicator IsRunning="{Binding IsSaving.Value}"
                                               IsVisible="{Binding IsSaving.Value}" />
                        </HorizontalStackLayout>

                        <!-- Merged result (visible after merge) -->
                        <Label Text="✓ Merged successfully"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Green700}"
                               IsVisible="{Binding IsMerged.Value}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Comments section header -->
                <Label Text="Conversation"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="0,8,0,4" />

                <!-- Comments list via BindableLayout -->
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Comments}"
                                     Spacing="8">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:Comment">
                            <Border Padding="14"
                                    StrokeShape="RoundRectangle 8"
                                    Stroke="{StaticResource Gray200}">
                                <VerticalStackLayout Spacing="6">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding User.Login}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource Primary}" />
                                        <Label Text="{Binding CreatedAt, StringFormat='{0:yyyy-MM-dd HH:mm}'}"
                                               FontSize="11"
                                               TextColor="{StaticResource Gray500}"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <idk:MarkdownView MarkdownText="{Binding Body}"
                                                      UseAppTheme="True"
                                                      H1FontSize="16"
                                                      H2FontSize="15"
                                                      H3FontSize="14"
                                                      TextFontSize="13" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- Comment input -->
                <VerticalStackLayout Spacing="8" Margin="0,8,0,0">
                    <Label Text="Add a comment"
                           FontSize="14"
                           FontAttributes="Bold" />
                    <Editor Text="{Binding CommentInput.Value}"
                            Placeholder="Write a comment... (Markdown supported)"
                            AutoSize="TextChanges"
                            FontSize="14"
                            MinimumHeightRequest="80" />
                    <Button Text="Comment"
                            Command="{Binding AddCommentCommand}"
                            IsEnabled="{Binding IsSaving.Value, Converter={StaticResource InvertedBoolConverter}}"
                            HorizontalOptions="Start"
                            Padding="24,8"
                            FontSize="14" />
                    <ActivityIndicator IsRunning="{Binding IsSaving.Value}"
                                       IsVisible="{Binding IsSaving.Value}" />
                </VerticalStackLayout>

                <!-- Error banner -->
                <Border IsVisible="{Binding ErrorMessage.Value, Converter={StaticResource StringToBoolConverter}}"
                        BackgroundColor="{StaticResource Red100}"
                        StrokeShape="RoundRectangle 8"
                        Padding="12">
                    <Label Text="{Binding ErrorMessage.Value}"
                           TextColor="{StaticResource Red900}"
                           FontSize="13" />
                </Border>

                <ActivityIndicator IsRunning="{Binding IsLoading.Value}"
                                   IsVisible="{Binding IsLoading.Value}" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
