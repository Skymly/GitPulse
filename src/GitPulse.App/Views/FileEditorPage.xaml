<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GitPulse.ViewModels;assembly=GitPulse.ViewModels"
             x:Class="GitPulse.App.Views.FileEditorPage"
             x:DataType="vm:FileEditorViewModel"
             Title="File Editor">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">

        <!-- Header: back + file name + actions -->
        <HorizontalStackLayout Grid.Row="0" Spacing="12" Padding="16,12,16,4">
            <Button Text="← Back"
                    Clicked="OnBackClicked"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    Padding="8,4" />
            <Label Text="{Binding Title.Value}"
                   FontSize="18"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   LineBreakMode="TailTruncation"
                   MaxLines="1" />
            <Button Text="Edit"
                    Command="{Binding ToggleEditCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    Padding="8,4"
                    FontSize="13"
                    VerticalOptions="Center"
                    IsVisible="{Binding IsEditing.Value, Converter={StaticResource InvertedBoolConverter}}" />
            <Button Text="GitHub →"
                    Command="{Binding OpenInBrowserCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    Padding="8,4"
                    FontSize="13"
                    VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!-- File path display -->
        <Label Grid.Row="1"
               Text="{Binding FilePath.Value}"
               FontSize="12"
               TextColor="{StaticResource Gray500}"
               Margin="16,0" />

        <!-- Error banner -->
        <Border Grid.Row="2"
                IsVisible="{Binding ErrorMessage.Value, Converter={StaticResource StringToBoolConverter}}"
                BackgroundColor="{StaticResource Red100}"
                StrokeShape="RoundRectangle 8"
                Padding="12"
                Margin="16,4,16,0">
            <Label Text="{Binding ErrorMessage.Value}"
                   TextColor="{StaticResource Red900}"
                   FontSize="13" />
        </Border>

        <!-- File content editor/viewer -->
        <Border Grid.Row="3"
                StrokeShape="RoundRectangle 8"
                Stroke="{StaticResource Gray200}"
                Margin="16,8,16,0"
                Padding="0">
            <Editor Text="{Binding FileContent.Value}"
                    IsReadOnly="{Binding IsEditing.Value, Converter={StaticResource InvertedBoolConverter}}"
                    FontFamily="OpenSansRegular"
                    FontSize="14"
                    Margin="8"
                    AutoSize="TextChanges" />
        </Border>

        <ActivityIndicator Grid.Row="3"
                           IsRunning="{Binding IsBusy.Value}"
                           IsVisible="{Binding IsBusy.Value}"
                           VerticalOptions="Start"
                           Margin="0,16,0,0" />

        <!-- Commit message input (visible in edit mode) -->
        <Entry Grid.Row="4"
               Text="{Binding CommitMessage.Value}"
               Placeholder="Commit message..."
               IsVisible="{Binding IsEditing.Value}"
               Margin="16,8,16,0"
               FontSize="14" />

        <!-- Action buttons -->
        <HorizontalStackLayout Grid.Row="5" Spacing="12" Padding="16,8,16,16" HorizontalOptions="Center">
            <Button Text="Save"
                    Command="{Binding SaveCommand}"
                    IsVisible="{Binding IsEditing.Value}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    Padding="24,8"
                    FontSize="13" />
            <Button Text="Cancel"
                    Command="{Binding ToggleEditCommand}"
                    IsVisible="{Binding IsEditing.Value}"
                    BackgroundColor="{StaticResource Gray200}"
                    TextColor="Black"
                    Padding="24,8"
                    FontSize="13" />
            <Button Text="Delete"
                    Command="{Binding DeleteCommand}"
                    IsVisible="{Binding IsEditing.Value, Converter={StaticResource InvertedBoolConverter}}"
                    BackgroundColor="{StaticResource Red900}"
                    TextColor="White"
                    Padding="24,8"
                    FontSize="13" />
        </HorizontalStackLayout>

    </Grid>

</ContentPage>
