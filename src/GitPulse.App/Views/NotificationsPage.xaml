<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GitPulse.ViewModels;assembly=GitPulse.ViewModels"
             xmlns:models="clr-namespace:GitPulse.Core.Models;assembly=GitPulse.Core"
             x:Class="GitPulse.App.Views.NotificationsPage"
             x:DataType="vm:NotificationsViewModel"
             Title="Notifications">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Header: unread count + refresh + mark all read -->
        <HorizontalStackLayout Grid.Row="0" Spacing="12" Padding="16,12,16,8">
            <Label Text="{Binding UnreadCount.Value, StringFormat='{0} unread'}"
                   FontSize="16"
                   FontAttributes="Bold"
                   VerticalOptions="Center" />
            <Button Text="Refresh"
                    Command="{Binding RefreshCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    Padding="12,4"
                    FontSize="13"
                    VerticalOptions="Center" />
            <Button Text="Mark all read"
                    Command="{Binding MarkAllAsReadCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    Padding="12,4"
                    FontSize="13"
                    VerticalOptions="Center"
                    IsVisible="{Binding UnreadCount.Value, Converter={StaticResource IntGreaterThanZeroConverter}}" />
        </HorizontalStackLayout>

        <!-- Error banner -->
        <Border Grid.Row="1"
                IsVisible="{Binding ErrorMessage.Value, Converter={StaticResource StringToBoolConverter}}"
                BackgroundColor="{StaticResource Red100}"
                StrokeShape="RoundRectangle 8"
                Padding="12"
                Margin="16,0">
            <Label Text="{Binding ErrorMessage.Value}"
                   TextColor="{StaticResource Red900}"
                   FontSize="13" />
        </Border>

        <!-- Notifications list -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Notifications}"
                        Margin="16,8,16,0"
                        SelectionMode="Single"
                        SelectionChanged="OnNotificationSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Notification">
                    <Border Margin="0,0,0,8"
                            Padding="14"
                            StrokeShape="RoundRectangle 8"
                            Stroke="{StaticResource Gray200}">
                        <VerticalStackLayout Spacing="4">
                            <HorizontalStackLayout Spacing="8">
                                <!-- Unread indicator dot -->
                                <Ellipse WidthRequest="8" HeightRequest="8"
                                         Fill="{StaticResource Primary}"
                                         IsVisible="{Binding Unread}" />
                                <Label Text="{Binding Subject.Title}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="12" Margin="0,2,0,0">
                                <Label Text="{Binding Subject.Type}"
                                       FontSize="11"
                                       TextColor="{StaticResource Primary}" />
                                <Label Text="{Binding Repository.FullName}"
                                       FontSize="11"
                                       TextColor="{StaticResource Gray500}" />
                                <Label Text="{Binding Reason}"
                                       FontSize="11"
                                       TextColor="{StaticResource Gray500}" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8" Margin="0,4,0,0">
                                <Button Text="Mark read"
                                        Command="{Binding BindingContext.MarkAsReadCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource Primary}"
                                        Padding="8,2"
                                        FontSize="12" />
                                <Button Text="Open →"
                                        Command="{Binding BindingContext.OpenInBrowserCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding Subject.LatestCommentUrl}"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource Primary}"
                                        Padding="8,2"
                                        FontSize="12" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsBusy.Value}"
                           IsVisible="{Binding IsBusy.Value}"
                           VerticalOptions="Start"
                           Margin="0,16,0,0" />

        <!-- Empty state -->
        <VerticalStackLayout Grid.Row="2"
                             IsVisible="{Binding Notifications.Count, Converter={StaticResource IntGreaterThanZeroConverter}, ConverterParameter=invert}"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="8">
            <Label Text="No notifications"
                   FontSize="18"
                   TextColor="{StaticResource Gray500}"
                   HorizontalOptions="Center" />
            <Label Text="Pull to refresh or wait for the next poll."
                   FontSize="13"
                   TextColor="{StaticResource Gray400}"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Polling status indicator -->
        <HorizontalStackLayout Grid.Row="3" Spacing="8" Padding="16,8" HorizontalOptions="Center">
            <Ellipse WidthRequest="6" HeightRequest="6"
                     Fill="{StaticResource Green700}"
                     IsVisible="{Binding IsPolling.Value}" />
            <Label Text="Polling"
                   FontSize="11"
                   TextColor="{StaticResource Gray500}"
                   IsVisible="{Binding IsPolling.Value}" />
        </HorizontalStackLayout>

    </Grid>

</ContentPage>
