<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GitPulse.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:GitPulse.App.Views"
    Title="GitPulse">

    <TabBar Route="MainTabBar">
        <ShellContent
            Title="Repos"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate views:ReposPage}"
            Route="ReposPage" />

        <ShellContent
            Title="Notifications"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate views:NotificationsPage}"
            Route="NotificationsPage" />

        <ShellContent
            Title="Search"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate views:SearchPage}"
            Route="SearchPage" />

        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

    <!-- Detail pages (navigated to via GoToAsync, not in TabBar) -->
    <ShellContent
        Title="Repository"
        ContentTemplate="{DataTemplate views:RepoDetailPage}"
        Route="RepoDetailPage" />

    <ShellContent
        Title="Issues"
        ContentTemplate="{DataTemplate views:IssuesPage}"
        Route="IssuesPage" />

    <ShellContent
        Title="Issue Detail"
        ContentTemplate="{DataTemplate views:IssueDetailPage}"
        Route="IssueDetailPage" />

    <ShellContent
        Title="New Issue"
        ContentTemplate="{DataTemplate views:CreateIssuePage}"
        Route="CreateIssuePage" />

    <ShellContent
        Title="Pull Requests"
        ContentTemplate="{DataTemplate views:PullRequestsPage}"
        Route="PullRequestsPage" />

    <ShellContent
        Title="PR Detail"
        ContentTemplate="{DataTemplate views:PullRequestDetailPage}"
        Route="PullRequestDetailPage" />

    <!-- M5: File browsing & editing -->
    <ShellContent
        Title="Files"
        ContentTemplate="{DataTemplate views:FileBrowserPage}"
        Route="FileBrowserPage" />

    <ShellContent
        Title="File Editor"
        ContentTemplate="{DataTemplate views:FileEditorPage}"
        Route="FileEditorPage" />

</Shell>
